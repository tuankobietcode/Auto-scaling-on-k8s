# ============================================================================
# Biến môi trường chung cho toàn bộ quá trình dựng cụm.
# Điền IP thật của 4 VM (OpenStack) vào đây, sau đó:  source 00-vars.env
# ----------------------------------------------------------------------------
# Topology (đúng theo Biểu đồ triển khai):
#   - HAProxy   : Load Balancer (server riêng, đứng trước web service)
#   - Master    : Control Plane  (kube-apiserver, etcd, scheduler, controller)
#   - Worker 1  : Workload & management (AI scaler / Prometheus / 1 web service)
#   - Worker 2  : Workload (các pod web service)
# ============================================================================

# ----- Địa chỉ IP (THAY các giá trị bên dưới) -----
export HAPROXY_IP="192.168.5.218"     # VM chạy HAProxy (Load Balancer)
export MASTER_IP="192.168.5.203"      # Master node (Control Plane)
export WORKER1_IP="192.168.5.216"     # Worker node 1 (Workload & management)
export WORKER2_IP="192.168.5.202"     # Worker node 2 (Workload)

# ----- Hostname (đặt trùng với /etc/hostname trên từng VM) -----
export MASTER_HOST="k8s-master"
export WORKER1_HOST="k8s-worker1"
export WORKER2_HOST="k8s-worker2"
export HAPROXY_HOST="k8s-haproxy"

# ----- Phiên bản phần mềm -----
export K8S_VERSION="1.30"             # dòng minor cho repo pkgs.k8s.io
export K8S_PKG_VERSION="1.30.4-1.1"   # version chính xác của gói apt (kubeadm/kubelet/kubectl)
export CALICO_VERSION="v3.28.0"       # CNI

# ----- Mạng Pod / Service -----
export POD_CIDR="10.244.0.0/16"       # dải IP cho Pod (Calico)
export SVC_CIDR="10.96.0.0/12"        # dải IP cho Service (mặc định kubeadm)

# ----- Cổng dịch vụ expose ra ngoài (NodePort) -----
export WEB_NODEPORT="30080"           # NodePort của carserv-svc (web service)
export APISERVER_PORT="6443"          # cổng kube-apiserver trên master
