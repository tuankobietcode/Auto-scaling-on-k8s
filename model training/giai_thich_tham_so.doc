<tr><td>LOOK_BACK</td><td>24 (2 giờ)</td><td>Cửa sổ lịch sử</td><td>Đủ ngữ cảnh ngắn hạn</td></tr>
<tr><td>Train/Val/Test</td><td>80/10/10</td><td>Chia dữ liệu</td><td>Chuẩn, theo thời gian</td></tr>
<tr><td>Số lớp GRU</td><td>2</td><td>Học phân cấp</td><td>Cân bằng năng lực</td></tr>
<tr><td>GRU units</td><td>50, 50</td><td>Dung lượng nhớ</td><td>Vừa, tránh overfit</td></tr>
<tr><td>Dense units</td><td>25</td><td>Thu hẹp đặc trưng</td><td>Funnel 50&rarr;25&rarr;1</td></tr>
<tr><td>Dropout</td><td>0.2</td><td>Chống overfit</td><td>Mức nhẹ–vừa</td></tr>
<tr><td>L2</td><td>0.001</td><td>Chống overfit</td><td>Phạt trọng số nhẹ</td></tr>
